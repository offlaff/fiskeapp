<!DOCTYPE html>
<html lang="en">
  <head>
    <script>
      window.coords = <%- JSON.stringify(coords) %>;
      window.coords.northeast = window.coords.northeast.map((cord) => {
       return parseFloat(cord)
      })
      window.coords.southwest = window.coords.southwest.map((cord) => {
       return parseFloat(cord)
      })

      window.coords.center = window.coords.center.map((cord) => {
       return parseFloat(cord)
      })
      console.log(window.coords)
    </script>
    <%- include('./partials/head.ejs') %>
  </head>
  <body>
    <%- include('./partials/navbar.ejs') %>

    <div id="map"></div>
    <div class="center-container">
      <div class="input-group">
        <div class="searchContainer">
          <input
            id="searchInput"
            type="search"
            class="form-control rounded"
            placeholder="Søk etter navn"
            aria-label="Search"
            aria-describedby="search-addon"
          />
          <button
            id="searchButton"
            type="button"
            class="btn btn-outline-primary"
            data-mdb-ripple-init
          >
            Søk
          </button>
        </div>
        <div class="filters">
          <h5>Filtrer år:</h5>
          <div>
            <input type="checkbox" id="input2024" name="2024" />
            <label for="2024">2024</label>
          </div>
          <div>
            <input type="checkbox" id="input2025" name="2025" checked />
            <label for="2025">2025</label>
          </div>
        </div>
      </div>
    </div>

    <div class="container p-3">
      <h4 class="text-center mb-4">Rapportert fangst</h4>

      <table class="table table-striped table-bordered">
        <thead class="thead-dark">
          <tr>
            <th>Navn</th>
            <th>Vekt</th>
            <th>Lengde</th>
            <th>Type agn</th>
            <th>Agn</th>
            <th>Dato</th>
            <th>Bilde</th>
            <% if (user && user.role === "admin") { %>
            <th class="isAdmin">Rediger</th>
            <% } %>
          </tr>
        </thead>
        <tbody id="salmon-table-body"></tbody>
      </table>
    </div>
    <div class="modal" tabindex="-1" role="dialog">
      <div class="modal-dialog" role="document">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Legg til fangst</h5>
            <button
              type="button"
              class="close"
              data-dismiss="modal"
              aria-label="Close"
            >
              <span aria-hidden="true">&times;</span>
            </button>
          </div>

          <div class="modal-body">
            <div class="form-group mb-3">
              <label>Navn på fisker</label>
              <input
                id="name"
                type="text"
                class="form-control"
                placeholder="Ola Nordmann"
              />
            </div>
            <div class="form-group mb-3">
              <label>Vekt (kg)</label>
              <input
                id="weight"
                type="text"
                class="form-control"
                placeholder="4,4"
              />
            </div>
            <div class="form-group mb-3">
              <label>Lengde (cm)</label>
              <input
                id="length"
                type="text"
                class="form-control"
                placeholder="75"
              />
            </div>
            <div class="form-group mb-3">
              <label>Agn</label>
              <select class="form-select" id="bait">
                <option value="flue">Flue</option>
                <option value="sluk">Sluk</option>
                <option value="wobbler">Wobbler</option>
              </select>
            </div>
            <div class="form-group mb-3">
              <label>Informasjon om agn:</label>
              <input
                id="baitInfo"
                type="text"
                class="form-control"
                placeholder="Eks. Møresild 16gram"
              />
            </div>
            <div class="form-group mb-3">
              <label>Dato (YYYY-MM-DD)</label>
              <input
                id="date"
                type="date"
                class="form-control"
                placeholder="2025-08-21"
              />
            </div>
            <div class="form-group mb-3">
              <label>Bilde</label>
              <input
                id="image"
                type="file"
                class="form-control"
                accept="image/png, image/jpeg, image/jpg"
              />
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-primary" id="saveBtn">
              Send inn til godkjenning
            </button>
            <button
              type="button"
              class="btn btn-secondary closebtn"
              data-dismiss="modal"
            >
              Lukk
            </button>
          </div>
        </div>
      </div>
    </div>
    <script src="/client.js"></script>
  </body>
</html>
